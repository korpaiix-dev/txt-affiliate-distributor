# ===== TXT Affiliate Distributor - ตัวแปรทั้งหมด (เพื่อนเติมค่าเอง) =====
# ก๊อปไฟล์นี้เป็น .env.local แล้วเติมค่า
# **ห้าม commit .env.local ขึ้น git เด็ดขาด** (มันคือ token ลับ)

# Shopee affiliate id ของบอส (ใช้ประกอบลิงก์ sub_id)
TXT_SHOPEE_AFFILIATE_ID=15353120392

# ที่เก็บข้อมูล links/posts/queue (ว่าง = โฟลเดอร์ปัจจุบัน)
TXT_STORAGE_DIR=

# ---------- YouTube Data API v3 (OAuth) ----------
# วิธีเอา token:
#  1) Google Cloud Console -> สร้างโปรเจกต์ -> เปิด "YouTube Data API v3"
#  2) สร้าง OAuth client (ประเภท Desktop) -> ได้ client_id + client_secret
#  3) ทำ OAuth ครั้งเดียว (scope: https://www.googleapis.com/auth/youtube.upload) -> เก็บ refresh_token
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=
YT_PRIVACY=public

# ---------- Facebook Page (Graph API) ----------
# วิธีเอา token:
#  1) developers.facebook.com -> สร้าง App
#  2) ขอ Page Access Token แบบ long-lived (สิทธิ์: pages_manage_posts, pages_read_engagement)
#  3) เอา Page ID ของเพจที่จะโพสต์
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
FB_API_VERSION=v19.0
